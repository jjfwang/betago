# Server
PORT=3000
HOST=0.0.0.0

# CORS / LAN access
ENABLE_CORS=true
CORS_ALLOW_PRIVATE_LAN=true
# Optional exact origins allowlist (comma-separated), e.g.
# CORS_ALLOWED_ORIGINS=http://192.168.1.20:3000,http://localhost:5173
CORS_ALLOWED_ORIGINS=

# AI turn simulation delay in milliseconds (for UX pacing)
AI_THINK_DELAY_MS=350

# In-memory caps (prevents unbounded growth for long-running server)
MAX_SESSIONS=1000
MAX_GAMES=500
MAX_ACTION_REQUESTS=300
MAX_AI_TURN_LOGS=500
MAX_MOVES_IN_PAYLOAD=160

# AI provider: deterministic | external | katago
# If unset, provider defaults to external when LLM_API_URL is set, otherwise deterministic.
AI_PROVIDER=deterministic

# AI runtime logs
# AI_LOG_ENABLED: high-level provider/model logs
# AI_LOG_PROMPT: include model payload/prompt-like content (may be verbose)
# AI_LOG_VERBOSE: includes low-level KataGo GTP command logs
AI_LOG_ENABLED=false
AI_LOG_PROMPT=false
AI_LOG_VERBOSE=false

# External LLM integration (used when AI_PROVIDER=external)
LLM_API_URL=
LLM_API_KEY=

# Timeout for external LLM API request in milliseconds
LLM_TIMEOUT_MS=8000

# KataGo integration (used when AI_PROVIDER=katago)
# Option A: provide a full shell command
# KATAGO_CMD="katago gtp -model /path/to/model.bin.gz -config /path/to/gtp.cfg"
KATAGO_CMD=

# Option B: provide binary + structured args
KATAGO_BIN=katago
KATAGO_MODEL=
KATAGO_CONFIG=
KATAGO_OVERRIDE_CONFIG=
KATAGO_EXTRA_ARGS=
KATAGO_TIMEOUT_MS=15000
MAX_KATAGO_SESSIONS=12
KATAGO_SESSION_TTL_MS=600000
